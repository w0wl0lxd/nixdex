# =============================================================================
# nixdex .gitignore — dual-track AI / DevEx hygiene (2026)
#
# Tracked: product source and canonical command-not-found shell assets
# Ignored: local AI instruction overrides, research dumps, dev tool configs,
#          tool scratch, secrets, build output
# =============================================================================

# ----- Rust / Cargo ----------------------------------------------------------
/target/
crates/*/target
**/*.rs.bk
# Cargo.lock is tracked for the binary workspace (applications lock).

# ----- Nix -------------------------------------------------------------------
result
result-*
.direnv/

# ----- Secrets & env ---------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*
credentials.json

# ----- OS / editor scratch ---------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# ----- Stale root copies / local dev configs ---------------------------------
/command-not-found.sh
/command-not-found.nu
/.cargo/config.toml
/.config/sccache/config.toml
/mise.toml

# ----- Code indexing / analysis cache ----------------------------------------
.codegraph/
.cache/
coverage/
lcov.info
*.profraw
*.profdata
mutants.out/
mutants.out.old/

# ----- Upstream / research dumps ---------------------------------------------
.upstream/
/research/
paths.cache

# ----- AI agent instruction files (local-only) --------------------------------
# Team product docs stay in CONTRIBUTING.md + README.md.
# Root CLAUDE.md / AGENTS.md are personal agent loaders; keep them untracked.
/AGENTS.md
/AGENTS.local.md
/AGENTS.override.md
/CLAUDE.md
/CLAUDE.local.md
/GEMINI.md
/AIDER.md
/CONTINUE.md
/.cursorrules

# Tool directories (session state, permissions, caches)
.claude/
.cursor/
.windsurf/
.codex/
.copilot/
.copilot-tracking/
.devin/
.maki/
.opencode/
.kilocode/
.agent/
.agents/
.ai/
.ai-output/
.openai/
.anthropic/
.tmpclaude-*/
*.codex
.codex-pr-body.md

# Lefthook / hook manager local (if ever added)
lefthook-local.yml

# Local unversioned scratch
/tmp/
/scratch/
*.local.toml
*.local.yaml
*.local.yml
*.local.json

# Nextest / sccache local state
.sccache/
target-nextest/

# Private local planning (never commit)
.plan/
